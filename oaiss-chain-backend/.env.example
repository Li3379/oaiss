# =============================================
# OAISS Chain Environment Variables
# Copy to .env and fill in your values
# =============================================

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=oaiss
MYSQL_PASSWORD=change_me_user_password

# JWT - MUST be at least 256 bits for HS256
JWT_SECRET=change_me_to_a_random_256bit_secret

# Redis (no password by default)
REDIS_PASSWORD=

# MinIO
MINIO_ACCESS_KEY=change_me_minio_access
MINIO_SECRET_KEY=change_me_minio_secret

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
