# =============================================
# OAISS CHAIN — Monorepo .gitignore
# =============================================

# ----- Environment & Secrets (NEVER commit) -----
.env
.env.*
!.env.example

# ----- Java / Maven / Spring Boot -----
oaiss-chain-backend/target/
*.class
*.jar
*.war
*.ear
*.nar
oaiss-chain-backend/.mvn/wrapper/maven-wrapper.jar
oaiss-chain-backend/BOOT-INF/
oaiss-chain-backend/cookies.txt
oaiss-chain-backend/test-output.txt
oaiss-chain-backend/test-result.txt

# ----- Python -----
__pycache__/
*.pyc
*.pyo

# ----- Node.js / Vue / Vite -----
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
oaiss-chain-frontend/write_script.js

# ----- Build artifacts -----
build/
out/

# ----- Docker volumes (local data) -----
mysql-data/
redis-data/
minio-data/

# ----- Fabric crypto materials (generated, never commit) -----
fabric-config/crypto/
fabric-config/channel-artifacts/
oaiss-chain-backend/src/main/resources/fabric/crypto/

# ----- Test results & coverage -----
test-results/
playwright-report/
coverage/
.nyc_output/

# ----- IDE -----
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs -----
*.log
logs/

# ----- Playwright -----
.playwright-cli/
.playwright-mcp/

# ----- Tool state (not project code) -----
.omc/
.omc*/
.claude/
.gstack/
.planning/
.entroly/

# ----- Chrome debug (browser-harness) -----
.chrome-debug/

# ----- Graphify cache -----
graphify-out/cache/

# ----- Tool-generated docs -----
docs/superpowers/

